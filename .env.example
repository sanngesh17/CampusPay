NODE_ENV=development

# --- Database (matches infra/docker-compose.yml) ---
DATABASE_URL=postgresql://tuitionflow:tuitionflow@localhost:5432/tuitionflow?schema=public

# --- XRPL ---
XRPL_NETWORK=testnet            # testnet | devnet
XRPL_WSS=wss://s.altnet.rippletest.net:51233
XRPL_ISSUER_SEED=               # funded via faucet in tests; never commit
XRPL_FAUCET_URL=https://faucet.altnet.rippletest.net/accounts

# --- Crypto / secrets ---
# Local libsodium path: 32-byte key, base64. Generate: openssl rand -base64 32
ENCRYPTION_KEY=
ENCRYPTION_KEY_REF=local        # KMS key id, or "local" to use ENCRYPTION_KEY above
JWT_SECRET=
PARTNER_WEBHOOK_HMAC_SECRET=
WEB_ORIGIN=http://localhost:5173

# --- Private encrypted object storage ---
PRIVATE_STORAGE=local           # local | s3
LOCAL_STORAGE_ROOT=.data/private
S3_ENDPOINT=                    # optional for AWS; set for MinIO/R2-compatible services
S3_REGION=ap-south-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# --- Config (config-driven rates/limits, never literals) ---
TCS_CONFIG_PATH=./config/tcs.json
RAIL_CONFIG_PATH=./config/rails.json
RAIL_CAP_INR_MINOR=2500000000   # ₹25 lakh in paise
