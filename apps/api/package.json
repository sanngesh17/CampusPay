{
  "name": "@tuitionflow/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "start": "node dist/main.js",
    "test": "jest -c test/jest-e2e.js",
    "test:e2e": "jest -c test/jest-e2e.js",
    "test:personas": "jest -c test/jest-personas.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node prisma/seed.ts",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/serve-static": "^5.0.5",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tuitionflow/domain": "workspace:*",
    "@tuitionflow/rails": "workspace:*",
    "@tuitionflow/xrpl": "workspace:*",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "pdf-lib": "^1.17.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/supertest": "^6.0.2",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2"
  }
}
